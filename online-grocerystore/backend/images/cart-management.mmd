sequenceDiagram
    actor User
    participant Frontend as Frontend (React/Redux)
    participant API as Backend API
    participant Controller as productController
    participant DB as MongoDB
    participant Storage as LocalStorage

    rect rgb(240,240,240)
    Note over User,Frontend: Add Item to Cart
    User->>Frontend: Select product and quantity
    Frontend->>API: GET /api/products/:id
    API->>Controller: getProductById(req.params.id)
    Controller->>DB: Product.findById(id)
    DB-->>Controller: Product details (countInStock, price)
    Controller-->>API: Product JSON
    API-->>Frontend: Product JSON
    alt In stock and quantity <= countInStock
        Frontend->>Frontend: Dispatch ADD_TO_CART
        Frontend->>Storage: Save cart items to LocalStorage
        Frontend-->>User: Show updated cart
    else Out of stock or invalid qty
        Frontend-->>User: Show error message
    end
    end

    rect rgb(240,240,240)
    Note over User,Frontend: Update Cart Item Quantity
    User->>Frontend: Change quantity in cart
    Frontend->>Frontend: Validate against countInStock
    alt Valid quantity
        Frontend->>Frontend: Dispatch UPDATE_CART_ITEM
        Frontend->>Storage: Persist updated items
        Frontend-->>User: Show updated totals
    else Invalid quantity
        Frontend-->>User: Show error message
    end
    end

    rect rgb(240,240,240)
    Note over User,Frontend: Remove Item from Cart
    User->>Frontend: Click remove item
    Frontend->>Frontend: Dispatch REMOVE_FROM_CART
    Frontend->>Storage: Persist updated items
    Frontend-->>User: Show updated cart
    end
