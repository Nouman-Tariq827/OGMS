sequenceDiagram
    actor Admin as Admin User
    participant Frontend as Frontend (React)
    participant Backend as Backend API
    participant Auth as authMiddleware.protect
    participant AdminGuard as authMiddleware.admin
    participant Controller as productController
    participant Upload as uploadRoutes
    participant DB as MongoDB

    rect rgb(240,240,240)
    Note over Admin,Frontend: Create Catalogue Items (Manual)
    Admin->>Frontend: Open Catalogue Management
    Admin->>Frontend: Enter product fields (name, brand, category, price, stock)
    Frontend->>Backend: POST /api/products (Bearer Token)
    Backend->>Auth: Validate Token
    Auth-->>Backend: req.user attached
    Backend->>AdminGuard: Check req.user.isAdmin
    alt Not admin
        AdminGuard-->>Frontend: 401 Not authorized as admin
        Frontend-->>Admin: Show not-authorized message
    else Admin ok
        Backend->>Controller: createProduct(req, res)
        Controller->>DB: Save product with category
        DB-->>Controller: Created product
        Controller-->>Backend: 201 Created
        Backend-->>Frontend: Product JSON
        Frontend-->>Admin: Show in catalogue list
    end
    end

    rect rgb(240,240,240)
    Note over Admin,Frontend: Upload Product Image
    Admin->>Frontend: Select image file
    Frontend->>Backend: POST /api/upload (multipart/form-data)
    Backend->>Upload: Handle multer storage
    Upload-->>Frontend: Return image path (/uploads/...)
    Frontend->>Backend: PUT /api/products/:id with image path
    Backend->>Controller: updateProduct(req, res)
    Controller->>DB: Save updated product (image)
    DB-->>Controller: Updated product
    Controller-->>Backend: 200 OK
    Backend-->>Frontend: Updated Product JSON
    Frontend-->>Admin: Image shown in catalogue
    end

    rect rgb(240,240,240)
    Note over Admin,Frontend: Bulk Catalogue Import (Optional)
    Admin->>Frontend: Upload CSV of products
    Frontend->>Backend: POST /api/upload (CSV file)
    Backend->>Upload: Store CSV
    Note over Backend,Controller: Parse CSV and create many products
    Controller->>DB: Product.insertMany(rows)
    DB-->>Controller: Created items
    Controller-->>Backend: 201 Created
    Backend-->>Frontend: Summary of imported items
    Frontend-->>Admin: Show catalogue updated
    end
