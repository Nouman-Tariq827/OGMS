sequenceDiagram
    actor User
    participant Frontend as Frontend (React/Redux)
    participant API as Backend API
    participant Auth as authMiddleware.protect
    participant Controller as orderController
    participant DB as MongoDB

    User->>Frontend: Review Cart & Shipping Details
    User->>Frontend: Click "Place Order"
    Frontend->>API: POST /api/orders (orderItems, shippingAddress, paymentMethod, prices)
    activate API
    API->>Auth: Validate Bearer Token
    alt Token invalid or missing
        Auth-->>API: 401 Not authorized
        API-->>Frontend: 401 Error (Not authorized)
    else Token valid
        Auth-->>API: Attach req.user
        API->>Controller: addOrderItems(req.body, req.user)
        activate Controller
        alt No order items
            Controller-->>API: 400 Error (No order items)
            API-->>Frontend: Show error message
        else Create order
            Controller->>DB: new Order({...}).save()
            DB-->>Controller: createdOrder (_id, totals, user)
            Controller-->>API: 201 createdOrder
            deactivate Controller
            API-->>Frontend: Show Order Confirmation (Order ID)
            Frontend->>User: Redirect to Order Details Page
        end
    end
    deactivate API
