sequenceDiagram
    actor User
    participant Frontend
    participant API as Backend API
    participant Controller as userController
    participant DB as MongoDB

    User->>Frontend: Submit Registration Form (name, email, password)
    Frontend->>API: POST /api/users
    API->>Controller: registerUser(req.body)
    Controller->>DB: User.findOne({ email })
    DB-->>Controller: userExists?

    alt User exists
        Controller-->>API: 400 User already exists
        API-->>Frontend: Error message
    else New user
        Controller->>DB: User.create({ name, email, password })
        DB-->>Controller: Created user (_id, isAdmin, etc.)
        Controller-->>API: 201 user + JWT token
        API-->>Frontend: Success response
    end
